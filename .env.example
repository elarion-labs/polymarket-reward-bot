# -------------------------------------------------------------------
# Polymarket API credentials
# -------------------------------------------------------------------

PRIVATE_KEY=
POLY_L2_API_KEY=
POLY_L2_SECRET=
POLY_L2_PASSPHRASE=

RPC_URL=https://polygon-rpc.com
CHAIN_ID=137


# -------------------------------------------------------------------
# Market selection
# -------------------------------------------------------------------

MARKET_SELECTION_MODE=AUTO
MANUAL_MARKET_FILE=manual_market.json


# -------------------------------------------------------------------
# Risk
# -------------------------------------------------------------------

BANKROLL_USDC=100
SAFE_CLOSE_HOURS=24
MAX_POSITION_USD=20
MAX_CAPITAL_PER_MARKET=40
FREE_USDC_BUFFER_PCT=0.30


# -------------------------------------------------------------------
# Quoting
# -------------------------------------------------------------------

MODE=SINGLE_SIDED_SAFE
TARGET_MIN_DISTANCE=0.01
TARGET_MAX_DISTANCE=0.02


# -------------------------------------------------------------------
# Repricing
# -------------------------------------------------------------------

REPRICE_THRESHOLD=0.01
JUMP_THRESHOLD=0.02
JUMP_WINDOW_SECONDS=60
COOLDOWN_MINUTES=10


# -------------------------------------------------------------------
# Loop
# -------------------------------------------------------------------

POLL_FALLBACK_SECONDS=15
MARKET_RESELECT_MINUTES=30


# -------------------------------------------------------------------
# Safety
# -------------------------------------------------------------------

UNHEDGED_MAX_SECONDS=20


# -------------------------------------------------------------------
# Rewards
# -------------------------------------------------------------------

MIN_DAILY_REWARD_USD=1.0
ALLOW_UNDER_MIN_PAYOUT=false